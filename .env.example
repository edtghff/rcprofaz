ADMIN_PASSWORD=change_me_strong_password

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=media
# Brauzer birbaşa Storage-ə yükləyir (anon public key — Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
# Limitlər (Supabase Dashboard → Storage → Global file size limit ilə eyni saxlayın)
SUPABASE_MAX_VIDEO_MB=50
SUPABASE_MAX_IMAGE_MB=25
# Siyahı: bucket/site/videos.json
